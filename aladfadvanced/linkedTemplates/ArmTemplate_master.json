{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "aladfadvanced"
		},
		"amLinkServiceAdvance_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'amLinkServiceAdvance'"
		},
		"linkService_json_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'linkService_json'"
		},
		"amLinkServiceAdvance_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://amsourceadvance.dfs.core.windows.net/"
		},
		"RestService_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://pokeapi.co/api/v2/pokemon"
		},
		"linkService_json_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://amsourceadvance.dfs.core.windows.net/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "aladfadvanced_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"amLinkServiceAdvance_accountKey": {
						"value": "[parameters('amLinkServiceAdvance_accountKey')]"
					},
					"linkService_json_accountKey": {
						"value": "[parameters('linkService_json_accountKey')]"
					},
					"amLinkServiceAdvance_properties_typeProperties_url": {
						"value": "[parameters('amLinkServiceAdvance_properties_typeProperties_url')]"
					},
					"RestService_properties_typeProperties_url": {
						"value": "[parameters('RestService_properties_typeProperties_url')]"
					},
					"linkService_json_properties_typeProperties_url": {
						"value": "[parameters('linkService_json_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}